{
  "permissions": {
    "allow": [
      "Bash(ffmpeg -version)",
      "Bash(ffmpeg -i vid.mp4 -vf \"fps=1\" -frames:v 8 /tmp/frame_%02d.png)",
      "Bash(where ffmpeg:*)",
      "Bash(powershell -command \"Get-Command ffmpeg -ErrorAction SilentlyContinue | Select-Object -ExpandProperty Source\")",
      "Bash(powershell -command \":*)",
      "Bash(powershell -command \"Get-ChildItem ''''C:/Users/John/AppData/Local/Temp/'''' | Where-Object {$_me -like ''''frame*''''} | Select-Object Name\")"
    ]
  }
}
